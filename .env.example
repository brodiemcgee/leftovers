# Leftovers — environment variables
# Copy to .env.local for local dev. Production secrets go in Vercel.

# ----- Supabase -----
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----- Up Bank -----
UP_CLIENT_ID=
UP_CLIENT_SECRET=
UP_WEBHOOK_SECRET=
UP_REDIRECT_URI=https://leftovers.app/api/connect/up/callback

# ----- Basiq -----
BASIQ_API_KEY=
BASIQ_WEBHOOK_SECRET=

# ----- Anthropic (Layer 3 categoriser) -----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ----- Stripe -----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ----- APNS (direct push) -----
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.brodiemcgee.leftovers
APNS_P8_KEY=

# ----- Sentry -----
SENTRY_DSN=

# ----- Symmetric encryption for OAuth tokens at rest -----
# 32+ random bytes, base64 or hex
ENCRYPTION_KEY=

# ----- Cron auth (optional fallback alongside Vercel cron header) -----
CRON_SECRET=
